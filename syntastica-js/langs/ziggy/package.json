{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/package.json",
  "name": "@cj-syntastica/lang-ziggy",
  "version": "0.7.0",
  "description": "Ziggy language support for cj-syntastica-js",
  "keywords": ["tree-sitter", "highlight", "parsing", "syntax"],
  "homepage": "https://github.com/casualjim/syntastica/tree/expand-languages/syntastica-js#readme",
  "bugs": "https://github.com/casualjim/syntastica/issues",
  "license": "MPL-2.0",
  "author": "casualjim",
  "files": ["ziggy.wasm"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casualjim/syntastica.git",
    "directory": "syntastica-js/langs/ziggy"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "env CFLAGS=-fPIC cargo build --profile release-wasm --target wasm32-unknown-emscripten",
    "postbuild": "cp \"${CARGO_TARGET_DIR:-../../../target}/wasm32-unknown-emscripten/release-wasm/syntastica_js_ziggy.wasm\" ziggy.wasm"
  }
}
